          <li class="en-only">Lawn mowing (mower &amp; trimmer)</li>
          <li class="en-only">Weeding flower beds</li>
          <li class="en-only">Watering plants (indoor / outdoor)</li>
          <li class="en-only">Trimming &amp; clearing branches</li>
          <li class="en-only">Gardening</li>
        </ul>
      </div>
      <div class="svc">
        <div class="ico">🧽</div>
        <h3 class="fr-only">Entretien de maison et autre</h3>
        <h3 class="en-only">House maintenance &amp; more</h3>
        <ul>
          <li class="fr-only">Lavage d'auto / de vitres</li>
          <li class="fr-only">Ménage / grand ménage</li>
          <li class="fr-only">Peinture / teinture</li>
          <li class="fr-only">Épicerie</li>
          <li class="fr-only">Gardiennage</li>
          <li class="en-only">Car washing / window cleaning</li>
          <li class="en-only">Cleaning / deep cleaning</li>
          <li class="en-only">Painting / staining</li>
          <li class="en-only">Groceries</li>
          <li class="en-only">Babysitting</li>
        </ul>
      </div>
    </div>
    <p class="andmore fr-only">… ET PLUS ENCORE</p>
    <p class="andmore en-only">… AND MORE</p>
  </div>
</section>

<!-- TAX RECEIPT (signature) -->
<section id="recu" class="receiptband">
  <div class="wrap">
    <div class="receipt-layout">
      <div class="receipt" aria-hidden="true">
        <div class="rhead">
          <span class="rtag">CIEC Parc-Extension</span>
          <span class="rstamp fr-only">REÇU FISCAL</span>
          <span class="rstamp en-only">TAX RECEIPT</span>
        </div>
